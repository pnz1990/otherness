# Boundary: CLI and UI
# Focus: CLI commands, output formatting, and embedded React UI
# Scope: cmd/kardinal/, web/src/ — no changes to reconcilers or CRD types

AGENT_ID=STANDALONE-CLI-UI
SCOPE=CLI and UI — kardinal commands, output formatting, kardinal explain/get/policy, embedded React UI
ALLOWED_AREAS=area/cli,area/ui
ALLOWED_MILESTONES=v0.2.0,v0.2.1,v0.3.0
ALLOWED_PACKAGES=cmd/kardinal,web/src,web/embed.go
DENY_PACKAGES=pkg/reconciler,pkg/graph,pkg/translator,api/v1alpha1
